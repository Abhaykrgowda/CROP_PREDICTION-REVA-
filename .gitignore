# ============================================
# Smart-Crop-Prediction — Root .gitignore
# ============================================

# ── Python ────────────────────────────────────
venv/
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pdb
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ── Node.js ───────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Build outputs ─────────────────────────────
dist/
dist-ssr/
build/
*.local

# ── Environment & secrets ─────────────────────
.env
.env.local
.env.*.local
# NOTE: .env.example files ARE committed (safe templates)

# ── ML artefacts ──────────────────────────────
*.pkl
*.h5
*.pt
*.onnx

# ── Database ──────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Logs ──────────────────────────────────────
logs/
*.log

# ── OS files ──────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE / editor ──────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Docker build artefacts ────────────────────
# (Dockerfile, docker-compose.yml, .dockerignore ARE committed)

# ── Test & coverage ───────────────────────────
coverage/
.nyc_output/
htmlcov/
.pytest_cache/
.coverage

# ── Misc / temporary ─────────────────────────
*.tmp
*.temp
*.bak
*.swp
*~

# ── User-uploaded data (runtime) ──────────────
ml_model/crop_photos/
ml_model/farmers.db
